# Supabase (https://supabase.com/dashboard → Project Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# Service role — server only, never expose to the browser (admin orders + catalog)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Legacy JWT session fallback (optional if using Supabase Auth only)
AUTH_SECRET=your-auth-secret



# Admin panel (/admin)

ADMIN_PASSWORD=your-secure-admin-password



# Public site URL — used for the Bustaniya logo in order confirmation emails
# NEXT_PUBLIC_SITE_URL=https://your-domain.com
# Optional: direct logo URL (CDN / Supabase storage) if you prefer not to use SITE_URL
# EMAIL_LOGO_URL=https://your-domain.com/bustaniya-logo.png

# Order confirmation email (customer gets order summary — no domain verify needed)

# Add to .env.local, then restart: npm run dev

#

# Gmail (recommended): Google Account → Security → 2-Step Verification → App passwords

# SMTP_USER=your-gmail@gmail.com

# SMTP_PASS=your-16-char-app-password-no-spaces

# SMTP_HOST=smtp.gmail.com

# SMTP_PORT=587

# EMAIL_FROM=Bustaniya <your-gmail@gmail.com>

#

# Optional Resend (needs domain verify to email any customer): https://resend.com

# RESEND_API_KEY=re_your_resend_api_key

